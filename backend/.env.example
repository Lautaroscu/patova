# ==============================================================================
#                  Patova API - Environment Configuration Template
# ==============================================================================
# Copy this file to '.env' and complete the values.
#
# IMPORTANT SECURITY WARNING FOR PRODUCTION (Cloud Run / GCP):
# DO NOT commit the '.env' file with real secrets to version control.
# When deploying to Google Cloud Run, it is highly recommended to store all
# sensitive secrets (like database credentials, API keys, and third-party tokens)
# in Google Secret Manager and reference them in your Cloud Run Service configuration.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. CORE APPLICATION CONFIGURATION
# ------------------------------------------------------------------------------
# [APP_ENV] Environment mode. Set to 'production' in your production environment.
# Recommended: production
APP_ENV=production

# [APP_NAME] Human-readable name of the application.
APP_NAME=Patova API

# [API_VERSION] The API version prefix.
API_VERSION=v1

# [LOG_LEVEL] Logging severity level.
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Recommended: INFO (or WARNING to reduce log volume in production)
LOG_LEVEL=INFO

# [PATOVA_API_KEY] ** SECRET **
# Secret key used for authenticating administrative endpoints (X-Patova-Key header).
# Generate a strong, random 32+ character string for production!
# Example generation command: openssl rand -hex 32
PATOVA_API_KEY=YOUR_SECURE_PRODUCTION_ADMIN_API_KEY_HERE

# ------------------------------------------------------------------------------
# 2. DATABASE & REDIS STORAGE CONFIGURATION
# ------------------------------------------------------------------------------
# [DATABASE_URL] ** SECRET **
# SQLAlchemy database connection string. Must support async connections (asyncpg).
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
#
# NOTE FOR GCP DEPLOYMENTS:
# If using Cloud SQL, you can connect via:
# A) Private IP (if inside a VPC with a Serverless VPC Access connector)
# B) Cloud SQL Auth Proxy (preferred for ease of use and security)
#    E.g. postgresql+asyncpg://<user>:<password>@127.0.0.1:5432/<dbname> (using sidecar/proxy)
# C) Public IP (make sure to restrict authorized networks/require SSL)
DATABASE_URL=postgresql+asyncpg://db_user:db_password@db_host_ip_or_domain:5432/db_name

# [REDIS_URL] ** SECRET **
# Connection URL for Redis, used for caching, rate limiting, and temporary state.
# Format: redis://[[username]:password]@host:port/[db]
# For SSL/TLS enabled Redis (e.g. Upstash or GCP Memorystore with TLS): rediss://...
# Recommended: Ensure high-availability/persistence setup if needed, or Memorystore.
REDIS_URL=redis://redis_host_ip_or_domain:6379/0

# ------------------------------------------------------------------------------
# 3. SCORING & ABUSE GUARD PARAMETERS
# ------------------------------------------------------------------------------
# [SUSPECT_SCORE_MIN] The minimum numeric score (0-100) to classify a phone number as "suspect".
SUSPECT_SCORE_MIN=21

# [BLOCK_SCORE_MIN] The minimum numeric score (0-100) to classify a phone number as "blocked" (high risk).
BLOCK_SCORE_MIN=61

# [VALIDATE_CACHE_ENABLED] Enable caching of API phone validation responses to minimize DB queries.
# Options: true, false
VALIDATE_CACHE_ENABLED=true

# [AUTO_BLOCK_THRESHOLD] Number of spam reports or score weight before a number is automatically auto-blocked.
AUTO_BLOCK_THRESHOLD=50

# [MAX_REPORTS_PER_DEVICE_PER_DAY] Daily quota of phone spam reports allowed from a single device (prevents spamming reports).
MAX_REPORTS_PER_DEVICE_PER_DAY=3

# [SPAM_REPUTATION_CACHE_TTL] Time to live (in seconds) for spam reputation scores cached in Redis.
# Default: 3600 (1 hour)
SPAM_REPUTATION_CACHE_TTL=3600

# [CACHE_INVALIDATION_REPORT_THRESHOLD] Number of new reports that will force invalidating the cached reputation before TTL.
CACHE_INVALIDATION_REPORT_THRESHOLD=5

# ------------------------------------------------------------------------------
# 4. RATE LIMITING & SECURITY
# ------------------------------------------------------------------------------
# [CORS_ORIGINS] Comma-separated list of origins allowed to access the API.
# Use '*' to allow all, or specific origins like 'https://patova.serra.agency,http://localhost:3000'.
CORS_ORIGINS=*

# [RATE_LIMIT_PER_MINUTE] Total global API requests allowed per minute across the platform.
RATE_LIMIT_PER_MINUTE=1000

# [RATE_LIMIT_PER_IP] Requests allowed per IP address/Token per time-window.
RATE_LIMIT_PER_IP=60

# [RATE_LIMIT_REDIS_WINDOW_SEC] Time window in seconds for the rate limiter.
# Default: 60 (1 minute)
RATE_LIMIT_REDIS_WINDOW_SEC=60

# ------------------------------------------------------------------------------
# 5. OBSERVABILITY & ERROR TRACKING (OPTIONAL BUT RECOMMENDED)
# ------------------------------------------------------------------------------
# [SENTRY_DSN] ** SECRET **
# Sentry Data Source Name for real-time error logging and performance tracking.
# Leave commented out or empty if not using Sentry.
# SENTRY_DSN=https://your_sentry_public_key@o0.ingest.sentry.io/your_project_id

# [SENTRY_TRACES_SAMPLE_RATE] Percentage of transactions to capture for APM/tracing (0.0 to 1.0).
# Recommended for production: 0.1 to 0.25 (to keep costs down), or 1.0 if traffic is low.
SENTRY_TRACES_SAMPLE_RATE=0.25

# ------------------------------------------------------------------------------
# 6. MERCADOPAGO PAYMENT INTEGRATION (PREMIUM FEATURES)
# ------------------------------------------------------------------------------
# [MP_ACCESS_TOKEN] ** SECRET **
# MercadoPago API authorization credentials.
# - Production token starts with: APP_USR-...
# - Sandbox/Testing token starts with: TEST-...
# Obtain from: https://www.mercadopago.com.ar/developers/panel/credentials
MP_ACCESS_TOKEN=APP_USR-YOUR-PROD-MERCADO-PAGO-ACCESS-TOKEN

# [MP_SANDBOX] Enable or disable Sandbox/Test mode for MercadoPago payments.
# Set to 'false' in production to accept real transactions!
# Options: true, false
MP_SANDBOX=false

# [MP_WEBHOOK_BASE_URL] ** SECRET/PUBLIC **
# The base URL where MercadoPago can reach your backend to send Instant Payment Notifications (IPNs)/Webhooks.
# Must be a public HTTPS URL (cannot be localhost).
# Example: https://api.patova.com or Cloud Run URL: https://patova-api-abc123xyz-uc.a.run.app
MP_WEBHOOK_BASE_URL=https://api.yourdomain.com
